# =============================================================================
# BetBot — environment configuration template
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# --- External APIs -----------------------------------------------------------
# The Odds API — https://the-odds-api.com  (free tier: 500 req/month)
ODDS_API_KEY=REMPLACE_PAR_TA_CLE
# Safety floor: scans are blocked once monthly quota drops below this many requests.
# Default 20 (≈ 3 days of automatic scans). Lower to 5 if you want to use every drop.
ODDS_QUOTA_MINIMUM=20

# Multi-sport: extends scans beyond football. Out-of-season leagues are
# automatically skipped via /v4/sports?all=false (free probe), so enabling
# these is safe quota-wise.
#   - Tennis covers ATP Grand Slams (only one is "active" at a time per year)
#   - Basketball covers NBA (Oct-Jun) + EuroLeague (Oct-May)
MULTI_SPORT_TENNIS=1
MULTI_SPORT_BASKETBALL=1

# football-data.org — https://www.football-data.org  (free tier)
FOOTBALL_DATA_API_KEY=REMPLACE_PAR_TA_CLE

# api-football.com — xG (Opta) + injuries + rest/congestion + lineups (paid plan
# recommended: xG/league enrichment is quota-heavy). Without it those signals are
# skipped and the model runs on Poisson+ELO+market.
# API_FOOTBALL_KEY=
# Attack-strength signals from api-football (need API_FOOTBALL_KEY). Default OFF
# to protect the free tier; turn ON on a paid plan.
#   FETCH_INJURIES=1   # confirmed absences → attack penalty
#   FETCH_FATIGUE=1    # short rest / fixture congestion (incl. midweek Europe) → attack penalty
# Weather (Open-Meteo, FREE, no key) — rain/wind lower expected goals → directly
# affects Over/Under totals. Recommended ON. Default OFF.
#   FETCH_WEATHER=1

# Tavily — live news search used by the local agent (optional).
# Without it, the local agent skips the news check.
# TAVILY_API_KEY=

# --- Email notifications -----------------------------------------------------
GMAIL_USER=ton_adresse@gmail.com
# Gmail App Password (16 chars) — Account → Security → App passwords
GMAIL_APP_PASSWORD=REMPLACE_16_CARACTERES
GMAIL_RECIPIENT=ton_adresse@gmail.com

# --- Telegram notifications (optional) ---------------------------------------
# Both must be set to enable Telegram. Bot tokens come from @BotFather;
# chat_id from a message to @userinfobot.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Strategy ----------------------------------------------------------------
BANKROLL=100.0
KELLY_FRACTION=0.25
MIN_VALUE_EDGE=0.04
MIN_MODEL_PROB=0.40
MIN_BOOK_ODDS=1.50
TOP_BETS=10
MIN_COMBOS=3
TOP_COMBOS=3
SCAN_HOURS=09:00,15:00,20:00
MIN_BEFORE_KICKOFF=60

# --- Derived markets: Double Chance + Draw No Bet ----------------------------
# Computed from the 1X2 we already fetch (0 extra API quota). They add lower-
# variance options and ideal favorite legs for combos. DC (1X/X2/12) never
# pushes; DNB refunds the stake on a draw. Set DERIVE_DC_DNB=0 to disable.
# DERIVE_DC_DNB=1
# Edge floor for a DC/DNB single/leg to be surfaced (they're +EV but thinner-
# edge than 1X2 — the payoff is reliability). Lower once calibration is trained.
# DERIVED_MIN_EDGE=0.02
# Odds floor for DC/DNB (they're low-odds by nature — separate from MIN_BOOK_ODDS)
# DERIVED_MIN_ODDS=1.10

# --- Responsible-betting guards ----------------------------------------------
# Hard limits enforced before bet placement. Set any to 0 to disable.
# STOP_LOSS_PCT=0.50           # halt scans if balance drops below 50% of total deposits
# MAX_DAILY_STAKE_PCT=0.20     # max stake per UTC day, as fraction of balance
# MAX_EXPOSURE_PCT=0.30        # max committed stake as fraction of gross capital
# MAX_BETS_PER_DAY=10          # numeric cap on bets per UTC day
# COOL_OFF_LOSSES=3            # consecutive losses that trigger cool-off
# COOL_OFF_HOURS=12            # cool-off duration after the trigger

# --- Database ----------------------------------------------------------------
# PostgreSQL is required. Quick start (Docker compose ships one):
#   docker compose up -d db
# DATABASE_URL=postgresql+psycopg2://betbot:betbot_dev_pwd@localhost:5432/betbot
# POSTGRES_PASSWORD=betbot_dev_pwd
# Host port for the dev db binding (container always uses db:5432 internally).
# Change it if 5432 is taken by another local Postgres (e.g. Odoo's bundled PG):
# DB_HOST_PORT=5433

# --- Offsite backups (optional) ----------------------------------------------
# The backup container dumps Postgres + the data volume to ./backups daily.
# To also push those files offsite (S3, Backblaze B2, Google Drive, Dropbox,
# SFTP, ...), use rclone:
#
#   1. Install rclone locally and configure your remote:
#        rclone config        # creates ~/.config/rclone/rclone.conf
#   2. Mount that config into the backup container by creating a file
#        docker-compose.override.yml  next to docker-compose.yml:
#
#        services:
#          backup:
#            volumes:
#              - ~/.config/rclone/rclone.conf:/root/.config/rclone/rclone.conf:ro
#
#   3. Set the target below (the part to the LEFT of `:` is the remote name
#        you chose in step 1, e.g. "b2-betbot:bucket/path"):
# BACKUP_REMOTE_TARGET=
# Optional: prune offsite copies older than N days (local retention is
# BACKUP_RETENTION_DAYS, default 30).
# BACKUP_REMOTE_RETENTION_DAYS=90
# BACKUP_RETENTION_DAYS=30

# --- Data paths (override only if you split the data volume) ----------------
# BASKETBALL_STATS_PATH=data/basketball_teams.json
# TENNIS_ELO_PATH=data/tennis_elo.json
# CALIBRATOR_PATH=data/calibrator.json
# SOURCE_HEALTH_STATE=data/source_health.json

# --- AI agent ----------------------------------------------------------------
# Without ANTHROPIC_API_KEY the API runs but POST /agent/recommend returns 503.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Logging -----------------------------------------------------------------
# LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=text             # text | json (json auto-detected inside containers)
# LOG_PATH=betbot.log         # empty string → stderr-only

# --- REST API auth -----------------------------------------------------------
# Leave password empty to disable auth (local-only). Set in production.
# API_BASIC_USER=betbot
# API_BASIC_PASSWORD=

# --- JWT auth (recommended for production) -----------------------------------
# When BETBOT_JWT_SECRET is set, /auth/login issues tokens. Generate the
# password hash with:
#   python -c "from passlib.context import CryptContext; \
#       print(CryptContext(schemes=['bcrypt']).hash('your_password'))"
# BETBOT_JWT_SECRET=
# BETBOT_USERNAME=betbot
# BETBOT_PASSWORD_HASH=
# Plaintext password fallback is REFUSED unless explicitly enabled. Setting
# BETBOT_ALLOW_PLAINTEXT_PASSWORD=1 opts into reading BETBOT_PASSWORD as-is —
# only acceptable for local dev.
# BETBOT_ALLOW_PLAINTEXT_PASSWORD=0
# BETBOT_PASSWORD=

# --- Security headers --------------------------------------------------------
# Enable HSTS only when serving over HTTPS in production.
# BETBOT_HSTS_ENABLED=0
# BETBOT_DOMAIN=  # restricts CORS to https://<domain> when set
