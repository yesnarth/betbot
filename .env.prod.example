# =============================================================================
# BetBot — PRODUCTION environment template (.env.prod.example)
# =============================================================================
# This file is a COMMITTABLE template. It must contain NO real secrets.
# Copy it to `.env` on the server, fill every REPLACE_ME, then deploy.
#
#   cp .env.prod.example .env
#   nano .env            # fill every REPLACE_ME with a real value
#
# `.env` is git-ignored (see .gitignore: .env, .env.local) — NEVER commit it,
# and never paste a real key/password into THIS template.
# =============================================================================
#
# -----------------------------------------------------------------------------
# DEPLOYMENT WALKTHROUGH (OVH VPS, public internet) — do these IN ORDER
# -----------------------------------------------------------------------------
# 1. DNS: create an A record for BETBOT_DOMAIN pointing at this VPS's public
#    IPv4 (and an AAAA record if you have IPv6). The cert will NOT issue until
#    DNS resolves to this host. Verify:  dig +short <your-domain>
#
# 2. Firewall: Caddy is the ONLY internet-facing service. The prod overlay
#    (docker-compose.prod.yml) applies `ports: !reset []` to db, redis, api and
#    dashboard, so Postgres (5432), Redis and the raw API/dashboard are NOT
#    reachable from the internet — only over the internal compose network.
#    Open EXACTLY the ports Caddy publishes (80, 443 TCP, 443 UDP for HTTP/3)
#    plus SSH. Example (ufw):
#       ufw allow OpenSSH
#       ufw allow 80/tcp
#       ufw allow 443/tcp
#       ufw allow 443/udp
#       ufw enable
#    Do NOT open 5432, 6379, 8000 or 8501.
#
# 3. (TESTING ONLY) To avoid Let's Encrypt rate-limits while you iterate,
#    uncomment the staging line in the Caddyfile:
#       # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
#    Re-comment it and clear caddy_data before the real production launch.
#
# 4. (FRESH INSTALL) Launch the full stack with BOTH compose files:
#       docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#    The one-shot `migrate` service (restart: no) runs `alembic upgrade head`
#    automatically once the db is healthy, before api/worker/dashboard start.
#
# 5. Wait for the certificate. Watch Caddy obtain the Let's Encrypt cert:
#       docker compose -f docker-compose.yml -f docker-compose.prod.yml logs -f caddy
#    Look for "certificate obtained successfully". Then verify HTTPS + HSTS:
#       curl -sSI https://<your-domain>/api/health | grep -i strict-transport
#
# -----------------------------------------------------------------------------
# RESTORING DATA FROM BACKUP (migrating an existing DB onto this VPS)
# -----------------------------------------------------------------------------
# Backups produced by the `backup` service are PAIRED files in ./backups/ :
#   betbot_<YYYYMMDD_HHMMSS>.sql.gz   (plain pg_dump piped through gzip -9)
#   data_<YYYYMMDD_HHMMSS>.tar.gz     (tennis ELO, basketball stats, calibrator)
#
# Restore the database BEFORE exposing the app. Bring up only db (+ its deps),
# load the dump, restore the data volume, THEN start everything:
#
#   # a) Start just the database (migrate will also run; that is fine — the
#   #    restore below DROPs and recreates the schema from the dump).
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d db
#
#   # b) Drop & recreate the target database (DESTRUCTIVE — that's the point):
#   docker compose exec db psql -U betbot -d postgres -c "DROP DATABASE IF EXISTS betbot;"
#   docker compose exec db psql -U betbot -d postgres -c "CREATE DATABASE betbot;"
#
#   # c) Restore the Postgres dump (note: user betbot, database betbot):
#   gunzip -c ./backups/betbot_<YYYYMMDD_HHMMSS>.sql.gz | \
#     docker compose exec -T db psql -U betbot -d betbot
#
#   # d) Restore the data volume (tennis ELO / basketball stats / calibrator):
#   docker compose run --rm -v "$(pwd)/backups:/host_backups" --entrypoint sh backup \
#     -c "tar -xzf /host_backups/data_<YYYYMMDD_HHMMSS>.tar.gz -C /app/data"
#
#   # e) Only now bring up the rest of the stack:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# See docs/RUNBOOK.md for the full procedure.
# =============================================================================

# #############################################################################
# ## PRODUCTION-REQUIRED — fill ALL of these before going live ################
# #############################################################################
#
# Your domain (the A record from step 1 must resolve to this server). Also
# restricts API CORS to https://<domain> and is required by Caddy for the
# Let's Encrypt certificate. Bare hostname, no scheme (e.g. betbot.example.com).
BETBOT_DOMAIN=REPLACE_ME
#
# Email for Let's Encrypt expiry / problem notifications (a real mailbox).
ACME_EMAIL=REPLACE_ME
#
# Strong PostgreSQL password. Postgres is NOT internet-exposed in prod, but a
# weak password is still a defense-in-depth failure. Generate one with:
#   openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME
#
# ---- API authentication (MANDATORY for a public deployment) ----------------
# The REST API is reachable at https://<domain>/api/* . It MUST require auth.
# Choose ONE of the two schemes below. Do NOT ship an open API.
#
# Scheme A — HTTP Basic (simplest):
API_BASIC_USER=REPLACE_ME
# !!! SECURITY !!! An EMPTY API_BASIC_PASSWORD DISABLES authentication entirely
# and leaves the API OPEN to the whole internet. It MUST be a strong value in
# production. Generate with:  openssl rand -base64 32
API_BASIC_PASSWORD=REPLACE_ME
#
# Scheme B — JWT (recommended; if you use this you may omit Basic auth above).
# /auth/login issues tokens when BETBOT_JWT_SECRET is set. Generate a secret
# with `openssl rand -base64 48` and a bcrypt hash for the password with:
#   python -c "from passlib.context import CryptContext; \
#       print(CryptContext(schemes=['bcrypt']).hash('your_password'))"
# Plaintext fallback is REFUSED unless BETBOT_ALLOW_PLAINTEXT_PASSWORD=1 — do
# NOT enable that on a public server.
# BETBOT_JWT_SECRET=REPLACE_ME
# BETBOT_USERNAME=betbot
# BETBOT_PASSWORD_HASH=REPLACE_ME
#
# The Odds API key — https://the-odds-api.com
ODDS_API_KEY=REPLACE_ME
# football-data.org key — https://www.football-data.org
FOOTBALL_DATA_API_KEY=REPLACE_ME
#
# #############################################################################

# --- External API options ----------------------------------------------------
# Safety floor: scans are blocked once monthly Odds quota drops below this many
# requests. Default 20 (≈ 3 days of automatic scans).
ODDS_QUOTA_MINIMUM=20
# Extend scans beyond football (out-of-season leagues auto-skipped). Optional.
MULTI_SPORT_TENNIS=1
MULTI_SPORT_BASKETBALL=1
# Optional feeds — omit to skip the corresponding check:
#   API_FOOTBALL_KEY=   # api-football.com injury/lineup feed
#   TAVILY_API_KEY=     # live news search for the local agent

# --- Notifications (optional) ------------------------------------------------
# Email (Gmail App Password = 16 chars from Account → Security → App passwords):
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# GMAIL_RECIPIENT=
# Telegram (BOTH required to enable):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Strategy ----------------------------------------------------------------
BANKROLL=100.0                 # total bankroll the staking is sized against
KELLY_FRACTION=0.25            # fractional Kelly (quarter-Kelly) for safety
MIN_VALUE_EDGE=0.04            # min model-vs-book edge to flag a value bet
MIN_MODEL_PROB=0.40            # ignore low-confidence model picks below this
MIN_BOOK_ODDS=1.50             # skip very short odds (poor value, high vig)
TOP_BETS=10                    # max single value bets surfaced per scan
MIN_COMBOS=3                   # min legs in a generated combo
TOP_COMBOS=3                   # max combos surfaced per scan
MIN_BEFORE_KICKOFF=60          # ignore matches starting within this many minutes

# Automatic scan schedule (UTC-naive local times). LEAVE EMPTY for manual-only
# scans (free Odds plan). On the paid plan, e.g. SCAN_HOURS=09:00,15:00,20:00
SCAN_HOURS=

# --- Responsible-betting guards (all optional; set to 0 to disable) ----------
# Recommended ON for a public/always-on deployment.
# STOP_LOSS_PCT=0.50           # halt scans if balance drops below this % of deposits
# MAX_DAILY_STAKE_PCT=0.20     # max stake per UTC day, as fraction of balance
# MAX_EXPOSURE_PCT=0.30        # max committed stake as fraction of gross capital
# MAX_BETS_PER_DAY=10          # numeric cap on bets per UTC day
# COOL_OFF_LOSSES=3            # consecutive losses that trigger a cool-off
# COOL_OFF_HOURS=12            # cool-off duration after the trigger

# --- Backups -----------------------------------------------------------------
# The `backup` service dumps Postgres + the data volume to ./backups daily at
# 03:00 UTC (and once at startup). Local retention default is 30 days.
BACKUP_RETENTION_DAYS=30
# Offsite copy (optional) — rclone target + remote retention. Requires mounting
# rclone.conf into the backup service (see .env.example / docker-compose.yml).
# BACKUP_REMOTE_TARGET=
# BACKUP_REMOTE_RETENTION_DAYS=90

# --- Security headers (production) -------------------------------------------
# Enable HSTS — valid because Caddy terminates HTTPS in prod (1-year max-age).
BETBOT_HSTS_ENABLED=1
# BETBOT_DOMAIN (set above) also restricts API CORS to https://<domain>.

# --- Logging -----------------------------------------------------------------
# LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=text              # text | json (json auto-detected in containers)
# In containers LOG_PATH is forced empty (stderr-only); leave it unset here.

# --- AI agent (optional) -----------------------------------------------------
# Without ANTHROPIC_API_KEY the API runs but POST /agent/recommend returns 503.
# ANTHROPIC_API_KEY=REPLACE_ME
# ANTHROPIC_MODEL=claude-sonnet-4-6
